@using System.Linq.Expressions

@if (ForceTooltip)
{
    <MudAvatar Style="width: 32px; height: 32px; vertical-align: middle; text-align: center;" Class="my-1" Color="ColorBack">
        <MudTooltip Text="@($"{For?.GetFieldSettings().Name}: {(Tooltip.NotEmpty() ? Tooltip : "N/A")}")">
            <MudIcon Icon="@Icon"></MudIcon>
        </MudTooltip>
    </MudAvatar>
}
else if (Text.Empty())
{
    <MudAvatar Style="width: 32px; height: 32px; vertical-align: middle; text-align: center;" Class="my-1" Color="ColorBack">
        <MudTooltip Text="@For?.GetFieldSettings().Name">
            <MudIcon Icon="@Icon" Color="ColorIcon"></MudIcon>
        </MudTooltip>
    </MudAvatar>
}
else
{
    <MudTooltip Text="@For?.GetFieldSettings().Name">
        <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size" Icon="@Icon" Class="my-1" Style="margin-inline: -4px;" Color="ColorBack">
            @Text
        </MudChip>
    </MudTooltip>
}

@code {
    [Parameter] public Expression<Func<object>>? For { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public bool ForceTooltip { get; set; }
    [Parameter] public string? Tooltip { get; set; }
    [Parameter] public Color ColorBack { get; set; } = Color.Default;
    [Parameter] public Color ColorIcon { get; set; } = Color.Default;
}
