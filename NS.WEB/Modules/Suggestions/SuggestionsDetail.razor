@page "/{culture}/suggestions/{id}"
@using NS.WEB.Modules.Country.Core
@using NS.WEB.Modules.Profile.Components
@using NS.WEB.Modules.Profile.Core

@inherits PageCore<SuggestionsDetail>

@inject SuggestionsApi SuggestionsApi
@inject LocalJsonApi LocalJsonApi
@inject WishListApi WishListApi

<HeadComponent Title="@SuggestionItem?.Title" Description="@SuggestionItem?.Description" Url="@($"/{Culture}/suggestions/{id}")" Index="true" Shared="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Icon="@IconsFA.Solid.Icon(Suggestion?.Icon).Font" Title="@SuggestionItem?.Title" Subtitle="@SuggestionItem?.SubTitle" Description="@SuggestionItem?.Description" UrlShare="@($"/{Culture}/suggestions/{id}")">
    <ActionsFragment>
        <MudSelect Value="@continent" ValueChanged="@((string? vl) => { continent = vl; ApplyFilter(); StateHasChanged(); })"
                   Label="Continent" FitContent="true" Clearable="true" Dense="true" Class="me-2" Variant="Variant.Text">
            @foreach (var item in AllRegions?.GetContinents() ?? [])
            {
                <MudSelectItem Value="item">@item</MudSelectItem>
            }
        </MudSelect>
    </ActionsFragment>
</PageSectionComponent>

<div class="grid-relative-container-big">
    @foreach (var item in FilteredSuggestions)
    {
        var _country = AllRegions?.GetByCode(item.Code);
        var _image = $"https://images.pexels.com/photos/{item.PhotoId}/pexels-photo-{item.PhotoId}.jpeg?auto=compress&cs=tinysrgb&h=550";
        var _altImage = item.CustomPhotoUrl.NotEmpty() ? item.CustomPhotoUrl : item.Code.GetFlag();

        <MudCard Style="position: relative;">
            <MudCardMedia Image="@(item.PhotoId.NotEmpty() ? _image : _altImage)" Height="300" />
            <MudChip T="string" Label="true" Color="Color.Secondary" Class="poster-chip" Style="top: 8px; left: 8px; position: absolute; margin: 0;" Size="AppStateStatic.Size">
                @if (ShowIndex)
                {
                    @($"{item.Index + "º"} - {_country?.name}")
                }
                else
                {
                    @_country?.name
                }
            </MudChip>
            <MudIconButton Style="top: 8px; right: 54px; position: absolute;" Icon="@IconsFA.Solid.Icon("add").Font" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => AddWishlist(item.Code!)">
            </MudIconButton>
            <MudIconButton Style="top: 8px; right: 8px; position: absolute;" Icon="@IconsFA.Solid.Icon("expand").Font" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => OpenPicture(item)">
            </MudIconButton>
            @if (item.Title.NotEmpty() || item.Description.NotEmpty())
            {
                <MudCardContent Style="text-align: justify;" Class="pa-2">
                    @if (item.Title.NotEmpty())
                    {
                        <MudText Typo="Typo.subtitle1" Color="Color.Default" Align="Align.Center" Style="line-height: 1.5">
                            @item.Title
                        </MudText>
                    }
                    @if (item.Description.NotEmpty())
                    {
                        <div class="mt-2">
                            <MudText Typo="Typo.caption">
                                @item.Description
                            </MudText>
                        </div>
                    }
                </MudCardContent>
            }
        </MudCard>
    }
</div>

<FloatingButton Template="Template.Back"></FloatingButton>

@code {
    [Parameter] public required string id { get; set; }

    public bool ShowIndex { get; set; } = true;

    private AllRegions? AllRegions { get; set; }
    public Suggestion? Suggestion { get; set; }
    public WishList? WishList { get; set; }

    private string? continent;
    private List<SuggestionRegion> FilteredSuggestions { get; set; } = [];

    private NS.Shared.Enums.SuggestionList[] Suggestions { get; set; } = [];
    private SuggestionCustomAttribute? SuggestionItem => Suggestions.SingleOrDefault(p => p.GetSuggestionCustomAttribute(false)?.Name == id).GetSuggestionCustomAttribute();

    protected override async Task ProcessInitialData()
    {
        Suggestions = EnumHelper.GetArray<NS.Shared.Enums.SuggestionList>();
        AllRegions = await LocalJsonApi.GetAllRegions();
        Suggestion = await SuggestionsApi.SuggestionGet(id);

        string[] bestTimeToGo = ["january", "february", "march", "april", "may", "june", "july", "august", "september", "october", "november", "december", "food-lovers"];

        if (bestTimeToGo.Contains(id))
        {
            ShowIndex = false;
        }

        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var FilteredRegions = AllRegions?.GetList(continent).Select(s => s.code) ?? [];
        FilteredSuggestions = Suggestion?.Regions.Where(p => FilteredRegions.Contains(p.Code)).ToList() ?? [];
    }

    private async Task AddWishlist(string code)
    {
        try
        {
            if (!AppStateStatic.IsAuthenticated)
            {
                await ShowWarning(GlobalTranslations.YouMustLogged);
                return;
            }

            WishList ??= await WishListApi.Get(AppStateStatic.IsAuthenticated);

            var parameters = new DialogParameters<WishlistPopup>
            {
                { x => x.AllRegions, AllRegions },
                { x => x.WishList, WishList },
                { x => x.Entry, new WishListEntry { RegionCode = code }  }
            };

            await DialogService.ShowAsync<WishlistPopup>("Wishlist", parameters, PopupHelper.Options(MaxWidth.Small));
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task OpenPicture(SuggestionRegion item)
    {
        try
        {
            var parameters = new DialogParameters<PicturePopup>
            {
                { x => x.Item, item },
                { x => x.AllRegions, AllRegions },
                { x => x.ShowIndex, ShowIndex }
            };
            await DialogService.ShowAsync<PicturePopup>("Picture", parameters, PopupHelper.Options(MaxWidth.Medium));
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }
}