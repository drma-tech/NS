@page "/{culture}/suggestions"
@using NS.WEB.Modules.Suggestions.Core

@inherits PageCore<SuggestionsPage>

<HeadComponent Title="@SeoTranslations.Suggestions" Description="@SeoTranslations.SuggestionsDesc" Url=@($"/{Culture}/suggestions") Index="true"></HeadComponent>

<PageSectionComponent Title="Destinations">
    <BodyFragment>
        <PageSectionComponent Title="@SeoTranslations.ThemesInterests" Description="@SeoTranslations.ThemesInterestsDesc" Color="Color.Secondary" CustomBodyClass="@Css.Build().Medium("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@ThemesInterests"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="@SeoTranslations.EventsFestivals" Description="@SeoTranslations.EventsFestivalsDesc" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@EventsFestivals"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Accommodations">
    <BodyFragment>
        <PageSectionComponent Title="Hotels" Color="Color.Secondary" CustomBodyClass="@Css.Build().Medium("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Hotels"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="Home Rental" Color="Color.Secondary" CustomBodyClass="@Css.Build().Medium("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@HomeRental"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="Alternative Stays" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@AlternativeStays"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Scores">
    <BodyFragment>
        <PageSectionComponent Title="@SeoTranslations.SocietyGovernment" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Scores100"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="@SeoTranslations.Economy" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Scores200"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="@SeoTranslations.SecurityPeace" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Scores300"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="@SeoTranslations.EnvironmentHealth" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Scores400"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
        <PageSectionComponent Title="@SeoTranslations.MobilityTourism" Color="Color.Secondary" CustomBodyClass="@Css.Build().Small("mb")" HasBodyBox="false">
            <BodyFragment>
                <SuggestionList Suggestions="@Scores500"></SuggestionList>
            </BodyFragment>
        </PageSectionComponent>
    </BodyFragment>
</PageSectionComponent>

@code {
