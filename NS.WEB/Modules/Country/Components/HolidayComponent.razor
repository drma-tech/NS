@using Heron.MudCalendar
@using NS.Shared.Models.Holiday
@using NS.WEB.Shared.Core
@inherits ComponentCore<HolidayComponent>

@inject CacheHolidayApi CacheHolidayApi

<PageSectionComponent Title="@SeoTranslations.NationalHolidays" Description="Global holidays calendar with categorized events by type" Icon="@IconsFA.Solid.Icon("calendar-days").Font">
    <BodyFragment>
        <MudTabs KeepPanelsAlive="true" MinimumTabWidth="100" ApplyEffectsToContainer="true" TabPanelsClass="@Css.Build().Small("pt")">
            <Header>
                <MudTooltip Text="Expand">
                    <MudIconButton Icon="@IconsFA.Solid.Icon("expand").Font" Color="Color.Primary" Href="@($"/{Culture}/explore/{Region}/holiday")" />
                </MudTooltip>
            </Header>
            <ChildContent>
                <MudTabPanel Text="All">
                    <RenderControl Actions="Actions" Context="ctx">
                        <MudCalendar Items="Items" ShowWeek="false" ShowDay="false" Height="500" MinDate="new DateTime(DateTime.Now.Year, 1, 1)" MaxDate="new DateTime(DateTime.Now.Year, 12, 31)">
                            <MonthTemplate>
                                @{
                                    var type = context.Text.Split('|')[0];
                                    var name = context.Text.Split('|')[1];
                                }
                                <MudTooltip Text="@name">
                                    <div class="ms-1 me-1">
                                        @if (type == "National holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("flag").WithSize(IconSize.sm).Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.Contains("Local holiday", StringComparison.CurrentCultureIgnoreCase))
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("house").WithSize(IconSize.sm).Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.IsReligiousHoliday())
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("place-of-worship").WithSize(IconSize.sm).Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.Contains("Observance", StringComparison.CurrentCultureIgnoreCase))
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("calendar-day").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Season")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("leaf").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Sporting event")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("trophy").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Clock change/Daylight Saving Time")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("clock").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Weekend")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("calendar-week").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Half-day holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("clock-rotate-left").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Optional holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("toggle-on").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("question").WithSize(IconSize.sm).Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                    </div>
                                </MudTooltip>
                            </MonthTemplate>
                        </MudCalendar>
                    </RenderControl>
                </MudTabPanel>
            </ChildContent>
        </MudTabs>
    </BodyFragment>
</PageSectionComponent>

<style>
    .mud-cal-month-cell-header {
        padding-bottom: 4px;
    }
</style>

@code {
    [Parameter][EditorRequired] public string? Region { get; set; }
    [Parameter][EditorRequired] public string? Culture { get; set; }

    public ComponentActions<CacheDocument<HolidayModel>?> Actions { get; set; } = new(obj => obj?.Data == null);
    private CacheDocument<HolidayModel>? Holiday { get; set; }
    private List<CalendarItem> Items => Holiday?.Data?.Items
        .Select(item => new CalendarItem { Start = item.date!.Value, Text = $"{item.type}|{item.name}", AllDay = true }).ToList() ?? [];

    protected override async Task ProcessComponentData()
    {
        if (Region.NotEmpty()) Holiday = await CacheHolidayApi.GetHoliday(Region, cts.Token);
        await Actions.FinishLoading.Invoke(Holiday);
    }

    private string? GetDayClass(DateTime date)
    {
        if (Holiday?.Data == null) return null;

        return Holiday.Data.Items.Select(item => item.date).Contains(date.Date) ? "holiday-day" : null;
    }
}
