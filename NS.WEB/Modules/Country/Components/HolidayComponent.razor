@using Heron.MudCalendar
@using NS.Shared.Models.Holiday
@using NS.WEB.Shared.Core
@inherits ComponentParameterCore<HolidayComponent>

@inject CacheHolidayApi CacheHolidayApi

<PageSectionComponent Title="@Translations.Module.Country.NationalHolidays" Description="Global holidays calendar with categorized events by type">
    <BodyFragment>
        <MudTabs KeepPanelsAlive="true" MinimumTabWidth="100" ApplyEffectsToContainer="true" TabPanelsClass="@Css.Build().Small("pt")">
            <Header>
                <MudTooltip Text="Expand">
                    <MudIconButton Icon="@Icons.Material.Filled.Fullscreen" Color="Color.Primary" OnClick="RedirectToHolidayPage" Rel="nofollow" />
                </MudTooltip>
            </Header>
            <ChildContent>
                <MudTabPanel Text="All">
                    <RenderControl Actions="Actions" Context="ctx">
                        <MudCalendar Items="Items" ShowWeek="false" ShowDay="false" Height="500" MinDate="new DateTime(DateTime.Now.Year, 1, 1)" MaxDate="new DateTime(DateTime.Now.Year, 12, 31)">
                            <MonthTemplate>
                                @{
                                    var type = context.Text.Split('|')[0];
                                    var name = context.Text.Split('|')[1];
                                }
                                <MudTooltip Text="@name">
                                    <div class="ms-1 me-1">
                                        @if (type == "National holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("flag").Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.Contains("Local holiday", StringComparison.CurrentCultureIgnoreCase))
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("house").Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.IsReligiousHoliday())
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("church").Font" Color="Color.Secondary" Size="Size.Small" />
                                        }
                                        else if (type.Contains("Observance", StringComparison.CurrentCultureIgnoreCase))
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("calendar-day").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Season")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("leaf").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Sporting event")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("trophy").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Clock change/Daylight Saving Time")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("clock").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Weekend")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("calendar-week").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Half-day holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("clock-rotate-left").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else if (type == "Optional holiday")
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("toggle-on").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@IconsFA.Solid.Icon("circle-question").Font" Color="Color.Tertiary" Size="Size.Small" />
                                        }
                                    </div>
                                </MudTooltip>
                            </MonthTemplate>
                        </MudCalendar>
                    </RenderControl>
                </MudTabPanel>
            </ChildContent>
        </MudTabs>
    </BodyFragment>
</PageSectionComponent>

<style>
    .mud-cal-month-cell-header {
        padding-bottom: 4px;
    }
</style>

@code {
    [Parameter][EditorRequired] public string? Region { get; set; }
    [Parameter][EditorRequired] public string? Culture { get; set; }

    public ComponentActions<CacheDocument<HolidayModel>?> Actions { get; set; } = new(obj => obj?.Data == null);
    private CacheDocument<HolidayModel>? Holiday { get; set; }
    private List<CalendarItem> Items => Holiday?.Data?.Items
        .Select(item => new CalendarItem { Start = item.date!.Value, Text = $"{item.type}|{item.name}", AllDay = true }).ToList() ?? [];

    protected override object GetParameterKey()
    {
        return new
        {
            Region,
            Culture
        };
    }

    protected override async Task LoadParameterDataAsync()
    {
        if (Region.NotEmpty()) Holiday = await CacheHolidayApi.GetHoliday(Region, Actions, cts.Token);
    }

    private string? GetDayClass(DateTime date)
    {
        if (Holiday?.Data == null) return null;

        return Holiday.Data.Items.Select(item => item.date).Contains(date.Date) ? "holiday-day" : null;
    }

    private void RedirectToHolidayPage()
    {
        Navigation.NavigateTo($"/{Culture}/explore/{Region}/holiday");
    }
}
