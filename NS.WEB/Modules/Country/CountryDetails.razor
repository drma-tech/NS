@page "/{culture}/explore/{code}"
@using NS.Shared.Models.Country
@using NS.WEB.Modules.Country.Components
@using NS.WEB.Modules.Country.Core
@using NS.WEB.Modules.Profile.Components
@using NS.WEB.Modules.Profile.Core
@using NS.Shared.Core.Helper
@using NS.WEB.Shared.Core

@inherits PageCore<CountryDetails>

@inject LocalJsonApi LocalJsonApi
@inject RegionsApi RegionsApi
@inject WishListApi WishListApi

<RenderControl Actions="ActionsAllRegions">
    <HeadComponent Title="@Region?.name" Description="@Region?.description" Url="@($"/{Culture}/explore/{Code}")" Image="@Region?.code.GetFlag()" Index="true" Shared="true"></HeadComponent>
    <PageSectionComponent IsPageHeader="true" Title="@Region?.name" Subtitle="@Region?.customName" Description="@Region?.description" Image="@Region?.code.GetFlag()" UrlShare="@($"/{Culture}/explore/{Code}")">
        <ExtraFragment>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.score)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.score)}")" Class="me-2"></MudIcon>
                @($"{GlobalTranslations.GlobalScore}: {(Region?.score != null ? Region?.score : "null")}")
            </MudChip>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.expensesScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.expensesScore)}")" Class="me-2"></MudIcon>
                @($"{GlobalTranslations.ExpensesScore}: {(Region?.expensesScore != null ? Region?.expensesScore : "null")}")
            </MudChip>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.safetyScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.safetyScore)}")" Class="me-2"></MudIcon>
                @($"{GlobalTranslations.SafetyScore}: {(Region?.safetyScore != null ? Region?.safetyScore : "null")}")
            </MudChip>
        </ExtraFragment>
        <ActionsFragment>
            @if (WishList != null)
            {
                @if (WishList?.Items.Any(a => a.RegionCode == Region?.code) ?? false)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="@Remove" Variant="Variant.Filled" Class="me-2">
                        @Button.Remove
                    </MudButton>
                }
                else
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="() => AddWishlist(Code)" Variant="Variant.Filled" Class="me-2">
                        @Button.Add
                    </MudButton>
                }
            }
        </ActionsFragment>
    </PageSectionComponent>
</RenderControl>

<RenderControl Actions="ActionsRegionData">
    <PageSectionComponent Title="@($"{SeoTranslations.Scores}: {RegionData?.GetGlobalScore()}")" Icon="@GetIntIcon(RegionData?.GetGlobalScore())">
        <BodyFragment>
            <MudTabs Border="true" Outlined="true" TabPanelsClass="pt-2" MinimumTabWidth="100px">
                <MudTabPanel Tag="1" Text="@($"{SeoTranslations.SocietyGovernment}: {context!.GetSocietyAndGovernmentScore()}")" Icon="@GetIntIcon(context!.GetSocietyAndGovernmentScore())" IconColor="@GetColorIcon(context.GetSocietyAndGovernmentScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @SeoTranslations.SocietyGovernmentDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.CorruptionScore)" Value="context.CorruptionScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.HDI)" Value="context?.HDI"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.DMDemocracyIndex)" Value="context.DMDemocracyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.EconomistDemocracyIndex)" Value="context.EconomistDemocracyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.FreedomExpressionIndex)" Value="context.FreedomExpressionIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.FreedomScore)" Value="context.FreedomScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.CensorshipIndex)" Value="context.CensorshipIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.HappinessIndex)" Value="context.HappinessIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="2" Text="@($"{SeoTranslations.Economy}: {context.GetEconomyScore()}")" Icon="@GetIntIcon(context.GetEconomyScore())" IconColor="@GetColorIcon(context.GetEconomyScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @SeoTranslations.EconomyDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.OECD)" Value="RegionData?.OECD"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.GDP_PPP)" Value="RegionData?.GDP_PPP"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.GDP_Nominal)" Value="RegionData?.GDP_Nominal"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.EconomicFreedomIndex)" Value="RegionData?.EconomicFreedomIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.CashlessIndex)" Value="RegionData?.CashlessIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="3" Text="@($"{SeoTranslations.SecurityPeace}: {context!.GetSecurityAndPeaceScore()}")" Icon="@GetIntIcon(context.GetSecurityAndPeaceScore())" IconColor="@GetColorIcon(context.GetSecurityAndPeaceScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @SeoTranslations.SecurityPeaceDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.TsaSafetyIndex)" Value="RegionData?.TsaSafetyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.NumbeoSafetyIndex)" Value="RegionData?.NumbeoSafetyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.GlobalTerrorismIndex)" Value="RegionData?.GlobalTerrorismIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.GlobalPeaceIndex)" Value="RegionData?.GlobalPeaceIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="4" Text="@($"{SeoTranslations.EnvironmentHealth}: {context!.GetEnvironmentAndHealthScore()}")" Icon="@GetIntIcon(context.GetEnvironmentAndHealthScore())" IconColor="@GetColorIcon(context.GetEnvironmentAndHealthScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @SeoTranslations.EnvironmentHealthDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.YaleWaterScore)" Value="RegionData?.YaleWaterScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.NumbeoPollutionIndex)" Value="RegionData?.NumbeoPollutionIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.AirQuality)" Value="RegionData?.AirQuality"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.HealthCareIndex)" Value="RegionData?.HealthCareIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.AnnualTemperature)" Value="RegionData?.AnnualTemperature"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="5" Text="@($"{SeoTranslations.MobilityTourism}: {context!.GetMobilityAndTourismScore()}")" Icon="@GetIntIcon(context.GetMobilityAndTourismScore())" IconColor="@GetColorIcon(context.GetMobilityAndTourismScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @SeoTranslations.MobilityTourismDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.VisaFree)" Value="RegionData?.CalculatePassportIndex()"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.TourismIndex)" Value="@(RegionData?.TourismIndex)"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.AirConnectivityIndex)" Value="@(RegionData?.AirConnectivityIndex)"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData For="@(() => context.SustainableMobilityIndex)" Value="@(RegionData?.SustainableMobilityIndex)"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </BodyFragment>
    </PageSectionComponent>

    <PageSectionComponent Title="@($"{SeoTranslations.Lifestyle}: {RegionData?.GetLifestyleScore()}")" Icon="@GetIntIcon(RegionData?.GetLifestyleScore())">
        <BodyFragment>
            <MudGrid Spacing="@Css.SpaceSmall">
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.Income)" Value="RegionData?.Income?.Avg" Score="RegionData?.Income?.Score" TranslateName="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.AptCityCenter)" Value="RegionData?.AptCityCenter?.Avg" Score="RegionData?.AptCityCenter?.Score" TranslateName="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.AptOutsideCenter)" Value="RegionData?.AptOutsideCenter?.Avg" Score="RegionData?.AptOutsideCenter?.Score" TranslateName="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.Meal)" Value="RegionData?.Meal?.Avg" Score="RegionData?.Meal?.Score" TranslateName="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.MarketWestern)" Value="@(RegionData?.MarketWestern?.Avg * 31)" Score="RegionData?.MarketWestern?.Score" TranslateName="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.MarketAsian)" Value="@(RegionData?.MarketAsian?.Avg * 31)" Score="RegionData?.MarketAsian?.Score" TranslateName="true"></ItemData>
                </MudItem>
            </MudGrid>
        </BodyFragment>
    </PageSectionComponent>

    <Advertising Slot="@AdSlot.Middle"></Advertising>

    <PageSectionComponent Title="@SeoTranslations.Guide">
        <BodyFragment>
            <MudGrid Spacing="@Css.SpaceSmall">
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.Risks
                    </MudChip>
                    <ItemIcon For="@(() => context!.Risks!.TransportTaxis)" Icon="@IconsFA.Solid.Icon("taxi").Font" ColorIcon="GetColorRisk(context!.Risks?.TransportTaxis)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.Pickpockets)" Icon="@IconsFA.Solid.Icon("wallet").Font" ColorIcon="GetColorRisk(context.Risks?.Pickpockets)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.NaturalDisasters)" Icon="@IconsFA.Solid.Icon("fire").Font" ColorIcon="GetColorRisk(context.Risks?.NaturalDisasters)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.Mugging)" Icon="@IconsFA.Solid.Icon("people-robbery").Font" ColorIcon="GetColorRisk(context.Risks?.Mugging)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.Terrorism)" Icon="@IconsFA.Solid.Icon("person-rifle").Font" ColorIcon="GetColorRisk(context.Risks?.Terrorism)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.Scams)" Icon="@IconsFA.Solid.Icon("user-ninja").Font" ColorIcon="GetColorRisk(context.Risks?.Scams)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.WomenTravelers)" Icon="@IconsFA.Solid.Icon("person-dress").Font" ColorIcon="GetColorRisk(context.Risks?.WomenTravelers)"></ItemIcon>
                    <ItemIcon For="@(() => context.Risks!.TapWater)" Icon="@IconsFA.Solid.Icon("faucet-drip").Font" ColorIcon="GetColorRisk(context.Risks?.TapWater)"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemsData For="@(() => context!.Languages)" Values="context!.Languages" OnlyText="true" TranslateName="true"></ItemsData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.Tipping
                    </MudChip>
                    <ItemIcon For="@(() => context!.Tipping!.Restaurant)" Text="@(context!.Tipping?.Restaurant ?? "Null")" Icon="@IconsFA.Solid.Icon("utensils").Font" ColorBack="Color.Info"></ItemIcon>
                    <ItemIcon For="@(() => context.Tipping!.Hotel)" Text="@(context.Tipping?.Hotel ?? "Null")" Icon="@IconsFA.Solid.Icon("hotel").Font" ColorBack="Color.Info"></ItemIcon>
                    <ItemIcon For="@(() => context.Tipping!.Driver)" Text="@(context.Tipping?.Driver ?? "Null")" Icon="@IconsFA.Solid.Icon("taxi").Font" ColorBack="Color.Info"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData For="@(() => context!.BroadbandSpeed)" Value="@($"{context!.BroadbandSpeed} Mbps")" ShowLabel="true" TranslateName="true"
                              Score="@DataHelper.ConvertToScore(context.BroadbandSpeed, 4.6, 172, true)" ForceScore="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.Taxes
                    </MudChip>
                    <ItemIcon For="@(() => context!.Taxes!.Corporate)" Tooltip="@context?.Taxes?.Corporate" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("building").Font" ColorBack="GetColorTax(context?.Taxes?.Corporate)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.IncomeLowest)" Tooltip="@context?.Taxes?.IncomeLowest" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("wallet").Font" ColorBack="GetColorTax(context?.Taxes?.IncomeLowest)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.IncomeHighest)" Tooltip="@context?.Taxes?.IncomeHighest" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("sack-dollar").Font" ColorBack="GetColorTax(context?.Taxes?.IncomeHighest)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.CapitalGains)" Tooltip="@context?.Taxes?.CapitalGains" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("chart-line").Font" ColorBack="GetColorTax(context?.Taxes?.CapitalGains)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.Wealth)" Tooltip="@context?.Taxes?.Wealth" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("gem").Font" ColorBack="GetColorTax(context?.Taxes?.Wealth)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.Property)" Tooltip="@context?.Taxes?.Property" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("house").Font" ColorBack="GetColorTax(context?.Taxes?.Property)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.InheritanceEstate)" Tooltip="@context?.Taxes?.InheritanceEstate" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("people-roof").Font" ColorBack="GetColorTax(context?.Taxes?.InheritanceEstate)"></ItemIcon>
                    <ItemIcon For="@(() => context!.Taxes!.VATGSTSales)" Tooltip="@context?.Taxes?.VATGSTSales" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("receipt").Font" ColorBack="GetColorTax(context?.Taxes?.VATGSTSales)"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.EmergencyNumbers
                    </MudChip>
                    <ItemIcon For="@(() => context!.EmergencyNumbers!.Police)" Tooltip="@context?.EmergencyNumbers?.Police" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("handcuffs").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Police)"></ItemIcon>
                    <ItemIcon For="@(() => context!.EmergencyNumbers!.Ambulance)" Tooltip="@context?.EmergencyNumbers?.Ambulance" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("truck-medical").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Ambulance)"></ItemIcon>
                    <ItemIcon For="@(() => context!.EmergencyNumbers!.Fire)" Tooltip="@context?.EmergencyNumbers?.Fire" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("fire-extinguisher").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Fire)"></ItemIcon>
                    <ItemIcon For="@(() => context!.EmergencyNumbers!.Others)" Tooltip="@context?.EmergencyNumbers?.Others" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("phone").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Others)"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemsData For="@(() => context!.Currencies)" Values="context!.Currencies" OnlyText="true" TranslateName="true"></ItemsData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.TravelRequirements
                    </MudChip>
                    <ItemIcon For="@(() => context.TravelRequirements.Accommodation)" Tooltip="@GetBoolString(context!.TravelRequirements?.Accommodation)" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("house").Font" ColorBack="GetColorRestrictions(context?.TravelRequirements?.Accommodation)"></ItemIcon>
                    <ItemIcon For="@(() => context.TravelRequirements.HealthInsurance)" Tooltip="@GetBoolString(context!.TravelRequirements?.HealthInsurance)" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("shield-heart").Font" ColorBack="GetColorRestrictions(context?.TravelRequirements?.HealthInsurance)"></ItemIcon>
                    <ItemIcon For="@(() => context.TravelRequirements.ReturnTicket)" Tooltip="@GetBoolString(context!.TravelRequirements?.ReturnTicket)" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("plane-departure").Font" ColorBack="GetColorRestrictions(context?.TravelRequirements?.ReturnTicket)"></ItemIcon>
                    <ItemIcon For="@(() => context.TravelRequirements.YellowFever)" Tooltip="@GetBoolString(context!.TravelRequirements?.YellowFever, true)" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("syringe").Font" ColorBack="GetColorRestrictions(context?.TravelRequirements?.YellowFever, true)"></ItemIcon>
                    <ItemIcon For="@(() => context.TravelRequirements.MinimumFunds)" Tooltip="@GetBoolString(context!.TravelRequirements?.MinimumFunds)" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("money-bill-wave").Font" ColorBack="GetColorRestrictions(context?.TravelRequirements?.MinimumFunds)"></ItemIcon>
                    <ItemIcon For="@(() => context.TravelRequirements.Warning)" Tooltip="@context!.TravelRequirements?.Warning" Icon="@IconsFA.Solid.Icon("circle-info").Font" ColorBack="@Color.Info" ColorIcon="Color.Surface"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.Religions
                    </MudChip>
                    @foreach (var item in context!.Religions)
                    {
                        <MudAvatar Style="width: 32px; height: 32px; vertical-align: middle; text-align: center; margin-inline: 2px;" Class="my-1" Color="Color.Info">
                            <MudTooltip Text="@($"{item.Religion.GetName()}: {item.Percent.ToString()}%")">
                                <MudIcon Icon="@IconsFA.Solid.Icon("church").Font"></MudIcon>
                            </MudTooltip>
                        </MudAvatar>
                    }
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Resources.Enum.Field.Electricity
                    </MudChip>
                    @foreach (var item in context!.Electricity?.Plugs ?? [])
                    {
                        <MudAvatar Style="width: 32px; height: 32px; vertical-align: middle; text-align: center; margin-inline: 2px;" Class="my-1" Color="Color.Default">
                            <MudTooltip Text="@($"Plug: {item}")">
                                <MudImage Src="@($"images/plugs/{item.ToLower()}.svg")" Style="width: 28px; height: 28px; vertical-align: middle;" Class="my-1"></MudImage>
                            </MudTooltip>
                        </MudAvatar>
                    }
                    @foreach (var item in context!.Electricity?.Voltages ?? [])
                    {
                        <MudChip T="string" Color="Color.Info" Style="padding-inline: 8px;">
                            @item
                        </MudChip>
