@page "/{culture}/explore/{code}"
@using NS.Shared.Models.Country
@using NS.Shared.Models.News
@using NS.WEB.Modules.Country.Components
@using NS.WEB.Modules.Country.Core
@using NS.WEB.Modules.Profile.Components
@using NS.WEB.Modules.Profile.Core
@using NS.Shared.Core.Helper
@using SD.WEB.Shared.Core

@inherits PageCore<CountryDetails>

@inject AllRegionsApi AllRegionsApi
@inject RegionsApi RegionsApi
@inject WishListApi WishListApi

<HeadComponent Title="@Region?.name" Description="@Region?.description" Url="@($"/{Culture}/explore/{Code}")" Image="@Region?.code.GetFlag()" Index="true" Shared="true"></HeadComponent>
<PageSectionComponent IsPageHeader="true" Title="@Region?.name" Subtitle="@Region?.customName" Description="@Region?.description" Image="@Region?.code.GetFlag()" UrlShare="@($"/{Culture}/explore/{Code}")">
    <ExtraFragment>
        <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
            <MudIcon Icon="@GetIntIcon(Region?.score)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.score)}")" Class="me-2"></MudIcon>
            @($"{GlobalTranslations.GlobalScore}: {(Region?.score != null ? Region?.score : "null")}")
        </MudChip>
        <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
            <MudIcon Icon="@GetIntIcon(Region?.costScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.costScore)}")" Class="me-2"></MudIcon>
            @($"{GlobalTranslations.CostScore}: {(Region?.costScore != null ? Region?.costScore : "null")}")
        </MudChip>
        <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
            <MudIcon Icon="@GetIntIcon(Region?.safetyScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.safetyScore)}")" Class="me-2"></MudIcon>
            @($"{GlobalTranslations.SafetyScore}: {(Region?.safetyScore != null ? Region?.safetyScore : "null")}")
        </MudChip>
    </ExtraFragment>
    <ActionsFragment>
        @if (WishList != null)
        {
            @if (WishList?.Items.Any(a => a.RegionCode == Region?.code) ?? false)
            {
                <MudButton StartIcon="@IconsFA.Solid.Icon("minus").Font" Color="Color.Error" OnClick="@Remove" Variant="Variant.Filled" Class="me-2">
                    @Button.Remove
                </MudButton>
            }
            else
            {
                <MudButton StartIcon="@IconsFA.Solid.Icon("plus").Font" Color="Color.Primary" OnClick="() => AddWishlist(Code)" Variant="Variant.Filled" Class="me-2">
                    @Button.Add
                </MudButton>
            }
        }
    </ActionsFragment>
</PageSectionComponent>

<GoogleAdSense Section="@GoogleAdSense.AdUnit.Explore"></GoogleAdSense>

