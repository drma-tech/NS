@page "/{culture}/explore/{code}"
@using NS.Shared.Models.Country
@using NS.WEB.Modules.Country.Components
@using NS.WEB.Modules.Country.Core
@using NS.WEB.Modules.Profile.Components
@using NS.WEB.Modules.Profile.Core
@using NS.Shared.Core.Helper
@using NS.WEB.Shared.Core

@inherits PageParameterCore<CountryDetails>

@inject LocalJsonApi LocalJsonApi
@inject RegionsApi RegionsApi
@inject WishListApi WishListApi

<RenderControl Actions="ActionsAllRegions">
    <HeadComponent Title="@Translations.Title.ExploreDetails.Format(Region?.name)" Description="@Region?.description" Url="@($"/{Culture}/explore/{Code}")" Image="@Region?.code.GetFlag()" Index="true" Shared="true"></HeadComponent>
    <PageSectionComponent IsPageHeader="true" Title="@Translations.Title.ExploreDetails.Format(Region?.name)" Subtitle="@Region?.customName" Description="@Region?.description" Image="@Region?.code.GetFlag()" UrlShare="@($"/{Culture}/explore/{Code}")">
        <ExtraFragment>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.score)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.score)}")" Class="me-2"></MudIcon>
                @($"{Translations.Module.Country.GlobalScore}: {(Region?.score != null ? Region?.score : "null")}")
            </MudChip>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.expensesScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.expensesScore)}")" Class="me-2"></MudIcon>
                @($"{Translations.Module.Country.ExpensesScore}: {(Region?.expensesScore != null ? Region?.expensesScore : "null")}")
            </MudChip>
            <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                <MudIcon Icon="@GetIntIcon(Region?.safetyScore)" Style="@($"margin-left: -6px; {GetColorStyle(Region?.safetyScore)}")" Class="me-2"></MudIcon>
                @($"{Translations.Module.Country.SafetyScore}: {(Region?.safetyScore != null ? Region?.safetyScore : "null")}")
            </MudChip>
        </ExtraFragment>
        <ActionsFragment>
            @if (WishList != null)
            {
                @if (WishList?.Items.Any(a => a.RegionCode == Region?.code) ?? false)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="@Remove" Variant="Variant.Filled" Class="me-2">
                        @Translations.Button.Remove
                    </MudButton>
                }
                else
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="() => AddWishlist(Code)" Variant="Variant.Filled" Class="me-2">
                        @Translations.Button.Add
                    </MudButton>
                }
            }
        </ActionsFragment>
    </PageSectionComponent>
</RenderControl>

<RenderControl Actions="ActionsRegionData">
    <PageSectionComponent Title="@($"{Translations.Module.Country.Scores}: {RegionData?.GetGlobalScore()}")" Icon="@GetIntIcon(RegionData?.GetGlobalScore())">
        <BodyFragment>
            <MudTabs Border="true" Outlined="true" TabPanelsClass="pt-2" MinimumTabWidth="100px">
                <MudTabPanel Tag="1" Text="@($"{Translations.Module.Country.SocietyGovernment}: {context!.GetSocietyAndGovernmentScore()}")" Icon="@GetIntIcon(context!.GetSocietyAndGovernmentScore())" IconColor="@GetColorIcon(context.GetSocietyAndGovernmentScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @Translations.Module.Country.SocietyGovernmentDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.CorruptionScore" Name="@NS.Shared.Translations.Enum.Field.Corruption" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.CorruptionScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context?.HDI" Name="@NS.Shared.Translations.Enum.Field.HDI" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.HDI"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.DMDemocracyIndex" Name="@NS.Shared.Translations.Enum.Field.Democracy" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.DMDemocracyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.EconomistDemocracyIndex" Name="@NS.Shared.Translations.Enum.Field.Democracy" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.EconomistDemocracyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.FreedomExpressionIndex" Name="@NS.Shared.Translations.Enum.Field.Expression" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.FreedomExpressionIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.FreedomScore" Name="@NS.Shared.Translations.Enum.Field.Freedom" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.FreedomScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.CensorshipIndex" Name="@NS.Shared.Translations.Enum.Field.Censorship" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.CensorshipIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="context.HappinessIndex" Name="@NS.Shared.Translations.Enum.Field.Happiness" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.HappinessIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="2" Text="@($"{Translations.Module.Country.Economy}: {context.GetEconomyScore()}")" Icon="@GetIntIcon(context.GetEconomyScore())" IconColor="@GetColorIcon(context.GetEconomyScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @Translations.Module.Country.EconomyDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.OECD" Name="@NS.Shared.Translations.Enum.Field.OECD" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.OECD"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.GDP_PPP" Name="@NS.Shared.Translations.Enum.Field.GDP_PPP" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.GDP_PPP"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.GDP_Nominal" Name="@NS.Shared.Translations.Enum.Field.GDP_Nominal" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.GDP_Nominal"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.EconomicFreedomIndex" Name="@NS.Shared.Translations.Enum.Field.Economic_Freedom" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.EconomicFreedomIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.CashlessIndex" Name="@NS.Shared.Translations.Enum.Field.Cashless_Index" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.CashlessIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="3" Text="@($"{Translations.Module.Country.SecurityPeace}: {context!.GetSecurityAndPeaceScore()}")" Icon="@GetIntIcon(context.GetSecurityAndPeaceScore())" IconColor="@GetColorIcon(context.GetSecurityAndPeaceScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @Translations.Module.Country.SecurityPeaceDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.TsaSafetyIndex" Name="@NS.Shared.Translations.Enum.Field.Safety" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.TsaSafetyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.NumbeoSafetyIndex" Name="@NS.Shared.Translations.Enum.Field.Safety" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.NumbeoSafetyIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.GlobalTerrorismIndex" Name="@NS.Shared.Translations.Enum.Field.Terrorism" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.GlobalTerrorismIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.GlobalPeaceIndex" Name="@NS.Shared.Translations.Enum.Field.Peace" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.GlobalPeaceIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="4" Text="@($"{Translations.Module.Country.EnvironmentHealth}: {context!.GetEnvironmentAndHealthScore()}")" Icon="@GetIntIcon(context.GetEnvironmentAndHealthScore())" IconColor="@GetColorIcon(context.GetEnvironmentAndHealthScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @Translations.Module.Country.EnvironmentHealthDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.YaleWaterScore" Name="@NS.Shared.Translations.Enum.Field.Sanitation_Water" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.YaleWaterScore"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.NumbeoPollutionIndex" Name="@NS.Shared.Translations.Enum.Field.Pollution" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.NumbeoPollutionIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.AirQuality" Name="@NS.Shared.Translations.Enum.Field.Air_Quality" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.AirQuality"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.HealthCareIndex" Name="@NS.Shared.Translations.Enum.Field.Health_Care" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.HealthCareIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.AnnualTemperature" Name="@NS.Shared.Translations.Enum.Field.Annual_Temperature" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.AnnualTemperature"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Tag="5" Text="@($"{Translations.Module.Country.MobilityTourism}: {context!.GetMobilityAndTourismScore()}")" Icon="@GetIntIcon(context.GetMobilityAndTourismScore())" IconColor="@GetColorIcon(context.GetMobilityAndTourismScore())">
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Dense="true" NoIcon="true" Class="mb-4" Style="text-align: justify;">
                        <MudText Typo="@(AppStateStatic.Size == Size.Small ? Typo.caption : Typo.body1)" Align="Align.Justify"
                                 Style="@($"line-height: {(IsDesktop ? "1.2" : "1.0")}; letter-spacing: {(IsDesktop ? "inherit" : "normal")};")">
                            @Translations.Module.Country.MobilityTourismDesc
                        </MudText>
                    </MudAlert>
                    <MudGrid Spacing="@Css.SpaceSmall">
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="RegionData?.CalculatePassportIndex()" Name="@NS.Shared.Translations.Enum.Field.Passport_Index" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.VisaFree"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="@(RegionData?.TourismIndex)" Name="@NS.Shared.Translations.Enum.Field.Tourism_Index" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.TourismIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="@(RegionData?.AirConnectivityIndex)" Name="@NS.Shared.Translations.Enum.Field.Air_Connectivity_Index" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.AirConnectivityIndex"></ItemData>
                        </MudItem>
                        <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                            <ItemData Value="@(RegionData?.SustainableMobilityIndex)" Name="@NS.Shared.Translations.Enum.Field.Sustainable_Mobility_Index" Placeholder="@NS.Shared.Translations.Enum.Field_OfficialName.SustainableMobilityIndex"></ItemData>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </BodyFragment>
    </PageSectionComponent>

    <PageSectionComponent Title="@($"{Translations.Module.Country.Lifestyle}: {RegionData?.GetLifestyleScore()}")" Icon="@GetIntIcon(RegionData?.GetLifestyleScore())">
        <BodyFragment>
            <MudGrid Spacing="@Css.SpaceSmall">
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="RegionData?.Income?.Avg" Score="RegionData?.Income?.Score" Name="@NS.Shared.Translations.Enum.Field.Income"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="RegionData?.AptCityCenter?.Avg" Score="RegionData?.AptCityCenter?.Score" Name="@NS.Shared.Translations.Enum.Field.AptCityCenter" Placeholder="@NS.Shared.Translations.Enum.Field.AptCityCenterDesc"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="RegionData?.AptOutsideCenter?.Avg" Score="RegionData?.AptOutsideCenter?.Score" Name="@NS.Shared.Translations.Enum.Field.AptOutsideCenter" Placeholder="@NS.Shared.Translations.Enum.Field.AptOutsideCenterDesc"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="RegionData?.Meal?.Avg" Score="RegionData?.Meal?.Score" Name="@NS.Shared.Translations.Enum.Field.Meal" Placeholder="@NS.Shared.Translations.Enum.Field.MealDesc"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="@(RegionData?.MarketWestern?.Avg * 31)" Score="RegionData?.MarketWestern?.Score" Name="@NS.Shared.Translations.Enum.Field.MarketWestern" Placeholder="@NS.Shared.Translations.Enum.Field.MarketWesternDesc"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="@(RegionData?.MarketAsian?.Avg * 31)" Score="RegionData?.MarketAsian?.Score" Name="@NS.Shared.Translations.Enum.Field.MarketAsian" Placeholder="@NS.Shared.Translations.Enum.Field.MarketAsianDesc"></ItemData>
                </MudItem>
            </MudGrid>
        </BodyFragment>
    </PageSectionComponent>

    <Advertising Slot="@AdSlot.Middle"></Advertising>

    <PageSectionComponent Title="@Translations.Module.Country.Guide">
        <BodyFragment>
            <MudGrid Spacing="@Css.SpaceSmall">
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Translations.Enum.Field.Risks
                    </MudChip>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("taxi").Font" ColorIcon="GetColorRisk(context!.Risks?.TransportTaxis)" Name="@NS.Shared.Translations.Enum.Field.TransportTaxis"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("wallet").Font" ColorIcon="GetColorRisk(context.Risks?.Pickpockets)" Name="@NS.Shared.Translations.Enum.Field.Pickpockets"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("fire").Font" ColorIcon="GetColorRisk(context.Risks?.NaturalDisasters)" Name="@NS.Shared.Translations.Enum.Field.NaturalDisasters"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("people-robbery").Font" ColorIcon="GetColorRisk(context.Risks?.Mugging)" Name="@NS.Shared.Translations.Enum.Field.Mugging"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("person-rifle").Font" ColorIcon="GetColorRisk(context.Risks?.Terrorism)" Name="@NS.Shared.Translations.Enum.Field.Terrorism"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("user-ninja").Font" ColorIcon="GetColorRisk(context.Risks?.Scams)" Name="@NS.Shared.Translations.Enum.Field.Scams"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("person-dress").Font" ColorIcon="GetColorRisk(context.Risks?.WomenTravelers)" Name="@NS.Shared.Translations.Enum.Field.WomenTravelers"></ItemIcon>
                    <ItemIcon Icon="@IconsFA.Solid.Icon("faucet-drip").Font" ColorIcon="GetColorRisk(context.Risks?.TapWater)" Name="@NS.Shared.Translations.Enum.Field.TapWater"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemsData Values="context!.Languages" OnlyText="true" Name="@NS.Shared.Translations.Enum.Field.Languages"></ItemsData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Translations.Enum.Field.Tipping
                    </MudChip>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Restaurant" Text="@(context!.Tipping?.Restaurant ?? "Null")" Icon="@IconsFA.Solid.Icon("utensils").Font" ColorBack="Color.Info"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Hotel" Text="@(context.Tipping?.Hotel ?? "Null")" Icon="@IconsFA.Solid.Icon("hotel").Font" ColorBack="Color.Info"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Driver" Text="@(context.Tipping?.Driver ?? "Null")" Icon="@IconsFA.Solid.Icon("taxi").Font" ColorBack="Color.Info"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemData Value="@($"{context!.BroadbandSpeed} Mbps")" ShowLabel="true" Name="@NS.Shared.Translations.Enum.Field.BroadbandSpeed" Placeholder="@NS.Shared.Translations.Enum.Field.BroadbandSpeedPlaceholder"
                              Score="@DataHelper.ConvertToScore(context.BroadbandSpeed, 4.6, 172, true)" ForceScore="true"></ItemData>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Translations.Enum.Field.Taxes
                    </MudChip>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Corporate" Tooltip="@context?.Taxes?.Corporate" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("building").Font" ColorBack="GetColorTax(context?.Taxes?.Corporate)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.IncomeLowest" Tooltip="@context?.Taxes?.IncomeLowest" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("wallet").Font" ColorBack="GetColorTax(context?.Taxes?.IncomeLowest)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.IncomeHighest" Tooltip="@context?.Taxes?.IncomeHighest" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("sack-dollar").Font" ColorBack="GetColorTax(context?.Taxes?.IncomeHighest)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.CapitalGains" Tooltip="@context?.Taxes?.CapitalGains" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("chart-line").Font" ColorBack="GetColorTax(context?.Taxes?.CapitalGains)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Wealth" Tooltip="@context?.Taxes?.Wealth" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("gem").Font" ColorBack="GetColorTax(context?.Taxes?.Wealth)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Property" Tooltip="@context?.Taxes?.Property" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("house").Font" ColorBack="GetColorTax(context?.Taxes?.Property)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.InheritanceEstate" Tooltip="@context?.Taxes?.InheritanceEstate" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("people-roof").Font" ColorBack="GetColorTax(context?.Taxes?.InheritanceEstate)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.VATGSTSales" Tooltip="@context?.Taxes?.VATGSTSales" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("receipt").Font" ColorBack="GetColorTax(context?.Taxes?.VATGSTSales)"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <MudChip T="string" Variant="Variant.Filled" Size="AppStateStatic.Size">
                        @NS.Shared.Translations.Enum.Field.EmergencyNumbers
                    </MudChip>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Police" Tooltip="@context?.EmergencyNumbers?.Police" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("handcuffs").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Police)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Ambulance" Tooltip="@context?.EmergencyNumbers?.Ambulance" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("truck-medical").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Ambulance)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Fire" Tooltip="@context?.EmergencyNumbers?.Fire" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("fire-extinguisher").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Fire)"></ItemIcon>
                    <ItemIcon Name="@NS.Shared.Translations.Enum.Field.Others" Tooltip="@context?.EmergencyNumbers?.Others" ForceTooltip="true" Icon="@IconsFA.Solid.Icon("phone").Font" ColorBack="GetColorTax(context?.EmergencyNumbers?.Others)"></ItemIcon>
                </MudItem>
                <MudItem xs="6" sm="4" md="3" xl="2" Style="padding-top: 4px;">
                    <ItemsData Name="@NS.Shared.Translations.Enum.Field.Currencies" Values="context!.Currencies" OnlyText="true"></ItemsData>
