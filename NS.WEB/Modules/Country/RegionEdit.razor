@page "/{culture}/regions-edit"

@using Microsoft.AspNetCore.Authorization
@using NS.WEB.Modules.Country.Core

@attribute [Authorize(Roles = "administrator")]

@inherits PageCore<RegionEdit>

@inject LocalJsonApi LocalJsonApi
@inject RegionsApi RegionsApi

<HeadComponent Title="platforms-edit" Description="platforms-edit" Url=@($"/{Culture}/platforms-edit") Index="false"></HeadComponent>

<MudButton OnClick="@SyncProvidersOnClick" Color="Color.Primary" Variant="Variant.Filled">
    Calculate Score
</MudButton>
<MudButton OnClick="@SaveSession" Color="Color.Primary" Variant="Variant.Filled">
    Save Session
</MudButton>

@code {
    private AllRegions? AllRegions { get; set; }

    protected override async Task ProcessPageData()
    {
        AllRegions = await LocalJsonApi.GetAllRegions();
    }

    protected async Task SyncProvidersOnClick()
    {
        try
        {
            if (AllRegions != null)
            {
                foreach (var item in AllRegions.Items)
                {
                    var region = await RegionsApi.GetRegion(item.code!);

                    item.score = region!.GetAverageScore();
                    item.lifestyleScore = region.GetLifestyleScore();
                    item.safetyScore = region.GetSafetyScore();
                }

                await SaveSession();
            }

            await ShowSuccess("Synchronization Finished");
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    protected async Task SaveSession()
    {
        if (AllRegions != null)
        {
            await JsRuntime.Utils().SetStorage("AllRegions", AllRegions);
        }
    }
}
