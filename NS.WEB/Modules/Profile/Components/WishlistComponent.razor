@inherits ComponentCore<WishlistComponent>

@using NS.WEB.Modules.Profile.Core
@using NS.WEB.Shared.Core

@inject WishListApi WishListApi

<PageSectionComponent Icon="@IconsFA.Solid.Icon("plane-circle-exclamation").Font" Title="@SeoTranslations.Wishlist">
    <ActionsFragment>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="@Add">
            @Button.Add
        </MudButton>
    </ActionsFragment>
    <BodyFragment>
        <RenderControl Actions="Actions">
            <div id="@_swiper" class="splide" role="group">
                <div class="splide__arrows">
                    <button class="splide__arrow splide__arrow--prev">
                        <MudIcon Icon="@IconsFA.Solid.Icon("circle-chevron-right").Font" Color="Color.Primary" Style="font-size: 30px;"></MudIcon>
                    </button>
                    <button class="splide__arrow splide__arrow--next">
                        <MudIcon Icon="@IconsFA.Solid.Icon("circle-chevron-right").Font" Color="Color.Primary" Style="font-size: 30px;"></MudIcon>
                    </button>
                </div>
                <div class="splide__track">
                    <ul class="splide__list">
                        @foreach (var item in WishList?.Items ?? [])
                        {
                            <li class="splide__slide">
                                <div class="swiper-slide" style="@($"width: {(IsMobile ? "150" : "200")}px")">
                                    <div style="position: relative;">
                                        <MudCard Outlined="true">
                                            <MudCardMedia Image="@item?.RegionCode.GetFlag()" Height="100" />
                                            <MudCardHeader Style="text-align: initial;" Class="pa-2">
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.body1" Color="Color.Secondary">@item?.RegionName</MudText>
                                                    <MudText Typo="Typo.body2">@(item?.CityName ?? "-")</MudText>
                                                </CardHeaderContent>
                                            </MudCardHeader>
                                            <MudCardActions Style="align-self: center;">
                                                <MudTooltip Text="Update">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => Update(item))" Size="Size.Small" />
                                                </MudTooltip>
                                                <MudTooltip Text="Delete">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => Delete(item))" Size="Size.Small" />
                                                </MudTooltip>
                                                <MudTooltip Text="Confirm Next Destination">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Check" OnClick="@(() => ConfirmNextDestination(item))" Size="Size.Small" />
                                                </MudTooltip>
                                            </MudCardActions>
                                        </MudCard>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </RenderControl>
    </BodyFragment>
</PageSectionComponent>

@code {
    [Parameter] public AllRegions? AllRegions { get; set; }
    [Parameter] public ComponentActions<WishList?> Actions { get; set; } = new(obj => obj == null || obj.Items.Empty());

    public WishList? WishList { get; set; }

    private readonly string _swiper = $"swiper-{Guid.NewGuid()}";
    private bool IsMobile => AppStateStatic.Breakpoint == Breakpoint.Xs;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        WishListApi.DataChanged += async (data) =>
        {
            WishList = data;
            Actions.CurrentInstance = data;
            await Actions.FinishLoading.Invoke(data);
            StateHasChanged();
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await base.OnAfterRenderAsync(firstRender);

            await JsRuntime.Slider().InitLists(_swiper, cts.Token, 200);
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    protected override async Task LoadAuthDataAsync()
    {
        await Actions.StartLoading.Invoke(null);
        WishList = await WishListApi.Get(AppStateStatic.IsAuthenticated, cts.Token);
        await Actions.FinishLoading.Invoke(WishList);
    }

    private async Task Add()
    {
        try
        {
            if (!AppStateStatic.IsAuthenticated)
            {
                await ShowWarning(GlobalTranslations.YouMustLogged);
                return;
            }

            var parameters = new DialogParameters<WishlistPopup>
            {
                { x => x.AllRegions, AllRegions },
                { x => x.WishList, WishList },
            };

            await DialogService.ShowAsync<WishlistPopup>("Wishlist", parameters, PopupHelper.Options(MaxWidth.Small));
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task Update(WishListEntry? entry)
    {
        try
        {
            var parameters = new DialogParameters<WishlistPopup>
            {
                { x => x.AllRegions, AllRegions },
                { x => x.WishList, WishList },
                { x => x.Entry, entry?.DeepClone() },
            };

            await DialogService.ShowAsync<WishlistPopup>("Wishlist", parameters, PopupHelper.Options(MaxWidth.Small));
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task Delete(WishListEntry? entry, bool confirm = true)
    {
        try
        {
            var confirmed = false;

            if (confirm)
                confirmed = await DialogService.ShowMessageBoxAsync(AppInfo.Title, GlobalTranslations.SureDelete, Button.Ok, Button.Cancel) ?? false;
            else
                confirmed = true;

            if (confirmed)
            {
                WishList = await WishListApi.Remove(entry?.Id, cts.Token);
            }
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

    private async Task ConfirmNextDestination(WishListEntry? entry)
    {
        try
        {
            if (!AppStateStatic.IsAuthenticated)
            {
                await ShowWarning(GlobalTranslations.YouMustLogged);
                return;
            }

            var parameters = new DialogParameters<NextDestinationsPopup>
            {
                { x => x.AllRegions, AllRegions },
                { x => x.Entry, new NextDestinationsEntry{ RegionCode = entry?.RegionCode, CityCode = entry?.CityCode, CheckList = entry?.CheckList ?? [] } },
                { x => x.PostSave, async (model) => await Delete(entry, false) }
            };

            await DialogService.ShowAsync<NextDestinationsPopup>("Next Destinations", parameters, PopupHelper.Options(MaxWidth.Small));
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }
}
