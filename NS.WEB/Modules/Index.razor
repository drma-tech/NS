@page "/"
@page "/{culture}"

@using NS.WEB.Modules.Country.Components
@using NS.WEB.Modules.Country.Core
@using NS.WEB.Modules.Explore.Components
@using NS.WEB.Modules.Subscription.Core
@using NS.WEB.Shared.Core

@inherits PageCore<Index>

@inject LocalJsonApi LocalJsonApi
@inject IpInfoApi IpInfoApi

<HeadComponent Title="@SeoTranslations.AppIndexTitle" Description="@SeoTranslations.AppDescription" Url=@($"/{Culture}") Index="true" Shared="true"></HeadComponent>

<PageSectionComponent IsPageHeader="true" Image="icon/icon-71.png" Title="@AppInfo.Title" Subtitle="@SeoTranslations.AppIndexTitle"></PageSectionComponent>

<RenderControl Actions="Actions">
    <MostVisitedCities AllRegions="AllRegions" Country="@country" Culture="@Culture"></MostVisitedCities>
    <GlobalCities AllRegions="AllRegions" Country="@country" Culture="@Culture"></GlobalCities>
    <BestDestinations AllRegions="AllRegions" Country="@country" Culture="@Culture"></BestDestinations>
</RenderControl>

<MudGrid Spacing="@Css.SpaceSmall">
    <MudItem xs="12" sm="6">
        <TopicNewsComponent Culture="@Culture"></TopicNewsComponent>
    </MudItem>
    <MudItem xs="12" sm="6">
    </MudItem>
</MudGrid>

@code {
    private AllRegions? AllRegions { get; set; }
    private ComponentActions<AllRegions?> Actions { get; set; } = new(obj => obj == null || obj.Items.Empty());
    private string? country;

    protected override async Task ProcessInitialData()
    {
        await Actions.StartLoading.Invoke(null);
        AllRegions = await LocalJsonApi.GetAllRegions();
        await Actions.FinishLoading.Invoke(AllRegions);

        country = await AppStateStatic.GetCountry(IpInfoApi, JsRuntime);
    }
}
