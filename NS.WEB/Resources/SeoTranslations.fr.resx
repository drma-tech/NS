    <value>Profil</value>
  </data>
  <data name="Regions" xml:space="preserve">
    <value>Régions</value>
  </data>
  <data name="Scores" xml:space="preserve">
    <value>Partitions</value>
  </data>
  <data name="ScoresIndexes" xml:space="preserve">
    <value>Partitions et indices</value>
  </data>
  <data name="ScoresIndexesDesc" xml:space="preserve">
    <value>Comparez les destinations à l'aide de scores et d'index globaux. Explorez les classements et les mesures pour évaluer les facteurs de sécurité, d'économie, d'environnement et de voyage.</value>
  </data>
  <data name="SecurityPeace" xml:space="preserve">
    <value>Sécurité et Paix</value>
  </data>
  <data name="SecurityPeaceDesc" xml:space="preserve">
    <value>Cette section donne un aperçu des aspects liés à la sécurité et à la paix du pays, notamment la sécurité publique, la perception de la criminalité, l'impact du terrorisme et la paix globale. Ces indicateurs aident à comprendre la stabilité et le niveau de sécurité personnelle et nationale au sein de la nation.</value>
  </data>
  <data name="SocietyGovernment" xml:space="preserve">
    <value>Société et gouvernement</value>
  </data>
  <data name="SocietyGovernmentDesc" xml:space="preserve">
    <value>Cette section donne un aperçu des aspects sociétaux et gouvernementaux du pays, notamment les niveaux de corruption, le développement humain, les indices de démocratie, la liberté d'expression et le bonheur général. Ces mesures aident à comprendre la qualité de la gouvernance et le bien-être social dans la nation.</value>
  </data>
  <data name="Suggestions" xml:space="preserve">
    <value>Suggestions</value>
  </data>
  <data name="SuggestionsDesc" xml:space="preserve">
    <value>Découvrez des suggestions de voyage sur My Next Spot en fonction de thèmes, d'intérêts, d'événements et de scores de destination pour vous aider à trouver votre prochaine destination idéale.</value>
  </data>
  <data name="ThemesInterests" xml:space="preserve">
    <value>Thèmes et intérêts</value>
  </data>
  <data name="ThemesInterestsDesc" xml:space="preserve">
    <value>Choisissez des destinations en fonction du type d'expérience que vous souhaitez vivre. Cette vue vous aide à explorer des lieux qui correspondent à votre humeur et à vos attentes de voyage.</value>
  </data>
  <data name="TravelHistory" xml:space="preserve">
    <value>Histoire de voyage</value>
  </data>
